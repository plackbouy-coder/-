{
  "entities": {
    "Player": {
      "title": "Player",
      "description": "User profile and game stats",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "wins": { "type": "number" },
        "losses": { "type": "number" },
        "elo": { "type": "number" },
        "region": { "type": "string" }
      },
      "required": ["uid", "username"]
    },
    "Room": {
      "title": "Room",
      "description": "Game room",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "status": { "type": "string", "enum": ["lobby", "playing", "finished"] },
        "players": { "type": "array" },
        "region": { "type": "string" }
      },
      "required": ["id", "status", "players"]
    },
    "Lobby": {
      "title": "Lobby",
      "description": "Waiting lobby",
      "type": "object",
      "properties": {
        "status": { "type": "string" },
        "category": { "type": "string" },
        "players": { "type": "array" }
      }
    }
  },
  "firestore": {
    "/players/{uid}": {
      "schema": "Player",
      "description": "User profiles"
    },
    "/rooms/{roomId}": {
      "schema": "Room",
      "description": "Active game rooms"
    },
    "/lobbies/{lobbyId}": {
      "schema": "Lobby",
      "description": "Active game lobbies"
    }
  }
}
